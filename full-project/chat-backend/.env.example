# MongoDB connection string (required)
# Local: mongodb://localhost:27017/chatapp
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/chatapp
MONGO_URI=mongodb://localhost:27017/chatapp

# JWT secret - change this to a long random string in production
JWT_SECRET=chat_app_super_secret_key_change_this_in_production

# Port (Render sets this automatically; 5000 is the local default)
PORT=5000
